# Supabase connection (public Vite vars — bundled into frontend JS)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-jwt-here

# Google OAuth client (used for Calendar integration)
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# Note: Edge Function secrets (RESEND_API_KEY, LOVABLE_API_KEY, etc.) are
# configured via Lovable Cloud, NOT in this file. They never appear
# in the frontend bundle.
